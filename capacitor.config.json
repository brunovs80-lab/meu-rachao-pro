{
  "appId": "com.meurachao.pro",
  "appName": "Meu Rachão Pro",
  "webDir": ".",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0D0D1A",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#121212"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "allowsLinkPreview": false
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#0D0D1A"
  }
}
