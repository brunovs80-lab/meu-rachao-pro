# Cloudflare Pages headers — meu-rachao-pro
# https://developers.cloudflare.com/pages/configuration/headers/

# Security defaults pra todas as rotas
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Imagens, ícones e logo: cache forte (versão fica no nome se mudar)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# CSS e JS: cache forte (mude o nome do arquivo se editar pra invalidar)
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

# Bundles do app
/www/js/*.bundle.js
  Cache-Control: public, max-age=31536000, immutable

# Manifest: cache curto (raramente muda mas precisa propagar rápido)
/manifest.json
  Cache-Control: public, max-age=3600

# Service Worker: NUNCA cachear (precisa atualizar pra usuário pegar nova versão)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Landing page: cache moderado
/landing/*
  Cache-Control: public, max-age=3600, must-revalidate

# Páginas legais
/privacy.html
  Cache-Control: public, max-age=86400

/terms.html
  Cache-Control: public, max-age=86400
