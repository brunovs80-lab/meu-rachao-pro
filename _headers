# Cloudflare Pages headers — meu-rachao-pro
# https://developers.cloudflare.com/pages/configuration/headers/

# Security defaults pra todas as rotas
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Imagens, ícones e logo (raiz, usados pela landing): cache forte
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# App: assets e bundles ficam em /app/
/app/assets/*
  Cache-Control: public, max-age=31536000, immutable

/app/css/*
  Cache-Control: public, max-age=31536000, immutable

/app/js/*
  Cache-Control: public, max-age=31536000, immutable

/app/js/*.bundle.js
  Cache-Control: public, max-age=31536000, immutable

# Manifest do app: cache curto (raramente muda mas precisa propagar rápido)
/app/manifest.json
  Cache-Control: public, max-age=3600

# Service Worker do app: NUNCA cachear (precisa atualizar pra usuário pegar nova versão)
/app/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# HTML do app: cache curto, must-revalidate (fallback ao SW network-first)
/app/index.html
  Cache-Control: public, max-age=300, must-revalidate

# Landing (raiz): cache moderado
/index.html
  Cache-Control: public, max-age=3600, must-revalidate

# Páginas legais
/privacy.html
  Cache-Control: public, max-age=86400

/terms.html
  Cache-Control: public, max-age=86400

/delete-account.html
  Cache-Control: public, max-age=86400
