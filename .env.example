# ===== Supabase =====
# https://supabase.com/dashboard -> Seu Projeto -> Settings -> API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=SUA-ANON-KEY-AQUI

# Service Role Key (poder total — bypassa RLS).
# Necessaria para o painel admin local. Pegue na mesma tela acima ("service_role").
# NUNCA commitar este valor.
SUPABASE_SERVICE_ROLE_KEY=SUA-SERVICE-ROLE-KEY-AQUI

# ===== Admin Panel (http://localhost:3000/admin) =====
# Senha de acesso ao painel. Use uma senha forte.
ADMIN_PASSWORD=troque-isso-por-uma-senha-forte

# Bind do servidor. Default 127.0.0.1 (so localhost responde).
# So mude para 0.0.0.0 se realmente precisar acessar da rede E nao tem nada
# sensivel acontecendo (cuidado: o painel admin tem acesso total ao banco).
ADMIN_BIND=127.0.0.1

# Porta do servidor (opcional, default 3000)
# PORT=3000
